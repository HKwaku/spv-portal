# =============================================================================
# Database — same idea as other Supabase projects: credentials from the dashboard
# =============================================================================
#
# Prisma needs a Postgres connection string (not the anon/service JWT keys).
# Supabase → Project Settings → Database → Connect → copy the Postgres URI
# (use "Transaction pooler" on port 6543 if Vercel/serverless has connection issues).
#
# Paste the real password — do not keep [brackets] from placeholder text.
# If the password contains ? # @ etc., URL-encode them in the URI (e.g. ? → %3F) or the URL is invalid.
#
DATABASE_URL="postgresql://postgres.laxzbgfgurpmzgutrrzi:6mTKsUdQS50iMPEj@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"


# Optional: same project URL as NEXT_PUBLIC_SUPABASE_URL in JS-only apps (not read by Prisma)
# NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# =============================================================================
# n8n (optional)
# =============================================================================
N8N_SPV_WEBHOOK_URL="https://YOUR_SUBDOMAIN.app.n8n.cloud/webhook/spv-new-entity"
N8N_BASE_URL="https://YOUR_SUBDOMAIN.app.n8n.cloud"

# =============================================================================
# Portal URL — callbacks from n8n
# =============================================================================
PORTAL_BASE_URL="http://localhost:3000"
