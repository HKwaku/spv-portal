# =============================================================================
# Database (required) — Prisma uses PostgreSQL
# =============================================================================
#
# Option A — Supabase (split fields)
#
# Use ONE of these ways to identify the server (not the long "Project ID" UUID):
#
# 1) Reference ID — Project Settings → General → "Reference ID" (short string).
#    Put it in SUPABASE_PROJECT_REF (we build host db.<ref>.supabase.co).
#
# 2) Or paste the DB host only — Project Settings → Database → host like db.xxxxx.supabase.co
#    into SUPABASE_DB_HOST (then SUPABASE_PROJECT_REF can be left empty).
#
# Password — Project Settings → Database → "Database password" (reset if unsure).
# If your password has # ? or spaces, wrap in double quotes: SUPABASE_DB_PASSWORD="..."
#
SUPABASE_PROJECT_REF=laxzbgfgurpmzgutrrzi
SUPABASE_DB_PASSWORD=Hkt070390??7

# Optional (usually unset — only if you use a non-default DB name/port or pooler host):
# SUPABASE_DB_HOST=db.your_reference_id.supabase.co
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_SSLMODE=require
#
# Option B — Any Postgres host: full URL (composition is skipped).
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spv"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# =============================================================================
# n8n (optional — intake webhook + wait-node resume)
# =============================================================================
N8N_SPV_WEBHOOK_URL="https://YOUR_SUBDOMAIN.app.n8n.cloud/webhook/spv-new-entity"

# Root URL of your n8n instance (no trailing slash). Used for /webhook-waiting/<externalWaitKey>
N8N_BASE_URL="https://YOUR_SUBDOMAIN.app.n8n.cloud"

# =============================================================================
# Portal URL — callbacks from n8n / links in automations
# =============================================================================
# Local: http://localhost:3000
# Production: https://your-app.vercel.app (match your Vercel deployment)
PORTAL_BASE_URL="http://localhost:3000"
