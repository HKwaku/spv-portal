# =============================================================================
# Database — Postgres URI from Supabase → Project Settings → Database → Connect
# =============================================================================
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true&sslmode=require"

# =============================================================================
# n8n — automation alongside the portal
# =============================================================================
# Intake (optional): fires when a new formation request is created
N8N_SPV_WEBHOOK_URL="https://YOUR_SUBDOMAIN.app.n8n.cloud/webhook/spv-new-entity"

# Root URL — used to resume WAIT nodes after a task is completed in the app
N8N_BASE_URL="https://YOUR_SUBDOMAIN.app.n8n.cloud"

# Optional — gate task completion: the portal POSTs here BEFORE writing status to the DB.
# Build a workflow: Webhook → your logic (APIs, approvals, etc.) → Respond to Webhook with JSON: { "allow": true }
# If unset, completion is saved immediately (portal-led mode).
# N8N_TASK_COMPLETION_WEBHOOK_URL="https://YOUR_SUBDOMAIN.app.n8n.cloud/webhook/spv-task-complete"
# N8N_COMPLETION_WEBHOOK_SECRET="shared-secret-for-Authorization-Bearer-if-you-want"

# Optional — set to "false" so the portal does NOT unlock the next checklist row after complete.
# Then your n8n workflow must call POST /api/tasks/sync for the next stepKey when automation reaches it.
# PORTAL_UNLOCK_NEXT_AFTER_COMPLETE="false"

# =============================================================================
# Portal URL — callbacks from n8n HTTP Request nodes
# =============================================================================
PORTAL_BASE_URL="http://localhost:3000"
