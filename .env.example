DATABASE_URL="file:./prisma/dev.db"

# n8n webhook URL — intake POST target
# n8n Cloud: https://<subdomain>.app.n8n.cloud/webhook/spv-new-entity
N8N_SPV_WEBHOOK_URL="https://hopetettey.app.n8n.cloud/webhook/spv-new-entity"

# n8n base URL — used by the portal to resume WAIT nodes
# Format: https://<subdomain>.app.n8n.cloud  (no trailing slash)
# The portal calls: ${N8N_BASE_URL}/webhook-waiting/<externalWaitKey>
N8N_BASE_URL="https://hopetettey.app.n8n.cloud"

# Portal base URL — used by n8n HTTP Request nodes to call back
# Local dev: http://localhost:3000
# Production: https://your-portal-domain.com
PORTAL_BASE_URL="http://localhost:3000"
